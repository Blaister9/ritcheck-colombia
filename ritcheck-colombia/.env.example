# ==========================================
# ARCHIVO: .env.example
# PROPOSITO: Plantilla de variables de entorno para RITCheck Colombia
# DEPENDENCIAS: Frontend, backend, workers, Supabase, Redis, Bold, Resend, IA
# LLAMADO DESDE: Desarrollo local, Vercel, Railway y CI/CD
# ==========================================

# App
NODE_ENV=development
APP_ENV=local
APP_TIMEZONE=America/Bogota
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
PUBLIC_APP_NAME=RITCheck Colombia
# DEMO_MODE: si es true Y NODE_ENV no es production, POST /api/orders
# crea la orden directamente en status=paid omitiendo Bold. NO usar en prod.
DEMO_MODE=false

# Frontend public variables
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_SUPABASE_URL=https://TODO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TODO_SUPABASE_ANON_KEY
NEXT_PUBLIC_BOLD_PUBLIC_KEY=TODO_BOLD_PUBLIC_KEY

# Backend
PORT=4000
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://TODO.vercel.app,https://ritcheck.co
JWT_AUDIENCE=authenticated
REQUEST_BODY_LIMIT=1mb
UPLOAD_MAX_BYTES=15728640
UPLOAD_ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# Supabase
SUPABASE_URL=https://TODO.supabase.co
SUPABASE_ANON_KEY=TODO_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=TODO_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET_RIT=rit-documents
SUPABASE_STORAGE_BUCKET_REPORTS=reports

# Redis / BullMQ
REDIS_URL=redis://localhost:6379
BULLMQ_PREFIX=ritcheck
ANALYSIS_QUEUE_NAME=rit-analysis
CLEANUP_QUEUE_NAME=rit-cleanup

# Bold Colombia
BOLD_API_BASE_URL=https://integrations.api.bold.co
BOLD_PUBLIC_KEY=TODO_BOLD_PUBLIC_KEY
BOLD_SECRET_KEY=TODO_BOLD_SECRET_KEY
BOLD_WEBHOOK_SECRET=TODO_BOLD_WEBHOOK_SECRET
BOLD_CURRENCY=COP

# Wompi fallback futuro
WOMPI_PUBLIC_KEY=TODO_WOMPI_PUBLIC_KEY
WOMPI_PRIVATE_KEY=TODO_WOMPI_PRIVATE_KEY
WOMPI_EVENTS_SECRET=TODO_WOMPI_EVENTS_SECRET

# Email
RESEND_API_KEY=TODO_RESEND_API_KEY
EMAIL_FROM=RITCheck Colombia <reportes@ritcheck.co>
EMAIL_REPLY_TO=soporte@ritcheck.co

# Claude
ANTHROPIC_API_KEY=TODO_ANTHROPIC_API_KEY
CLAUDE_MODEL=claude-3-5-sonnet-latest
CLAUDE_MAX_OUTPUT_TOKENS=12000
CLAUDE_TIMEOUT_MS=90000

# OpenAI
OPENAI_API_KEY=TODO_OPENAI_API_KEY
OPENAI_MODEL=gpt-5.5
OPENAI_TIMEOUT_MS=90000

# PDF
PDF_RENDER_TIMEOUT_MS=60000
REPORT_SIGNED_URL_TTL_SECONDS=604800

# Security
RATE_LIMIT_REDIS_URL=redis://localhost:6379
GLOBAL_RATE_LIMIT_WINDOW_MS=60000
GLOBAL_RATE_LIMIT_MAX=120
WEBHOOK_RATE_LIMIT_MAX=300
DOCUMENT_RETENTION_DAYS=7
LOG_LEVEL=info

# Manual review MVP
ENABLE_MANUAL_REVIEW=true
REVIEWER_EMAIL=edwin@TODO.com

