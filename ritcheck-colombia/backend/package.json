{
  "_fileHeader": "ARCHIVO: backend/package.json | PROPOSITO: Configura dependencias y scripts del backend Express y workers | DEPENDENCIAS: Express, BullMQ, Supabase, Claude, OpenAI, Playwright | LLAMADO DESDE: Railway y desarrollo local",
  "_todo": "TODO: fijar lockfile y separar paquetes de worker/API si el deploy lo requiere.",
  "name": "ritcheck-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker:analysis": "tsx src/workers/analysisWorker.ts",
    "worker:cleanup": "tsx src/workers/cleanupWorker.ts",
    "typecheck": "tsc --noEmit",
    "worker": "tsx --env-file=.env src/workers/analysisWorker.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@supabase/supabase-js": "^2.45.0",
    "bullmq": "^5.30.2",
